{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": "./",
    "paths": {
      "assets/*": ["assets/*"],
      "src/*": ["src/*"],
    },
    "allowSyntheticDefaultImports": true,
    "types": ["react", "react-native", "node"],
    "jsx": "react-native",
    "lib": ["es6", "dom", "esnext"],
    "module": "ESNext",
    "target": "esnext",
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules",
    "babel.config.js",
    "metro.config.js",
    "jest.config.js",
    ".eslint.config.js",
    "node_modules",
    "webpack.config.js",
    "**/*.spec.ts",
    "dist",
    "docs"
  ]
}
